{
	"name": "DS_SQL_OUTPUT_Parquet",
	"properties": {
		"linkedServiceName": {
			"referenceName": "SQL_OUTPUT_Parquet",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Table_Name": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat(dataset().Table_Name,'_',formatDateTime(utcNow(),'yyyyMMddHHmmss'),'.parquet')",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat(dataset().Table_Name,'/',formatDateTime(utcNow(),'yyyy/MM/dd'))\n\n",
					"type": "Expression"
				},
				"fileSystem": "sql-parquet-output"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}