{
	"name": "PL_SQL_TO_ADLSParquet",
	"properties": {
		"activities": [
			{
				"name": "cpy_SQL_to_ADLSparquet",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
